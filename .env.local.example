# Required environment variables
# Copy this file to .env.local for local development

# Supabase project URL (found in Project Settings > API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key (secret — never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Random secret for signing session cookies (≥ 32 characters recommended)
# Generate with: openssl rand -base64 32
SESSION_SECRET=your-random-32-char-secret-here

# Optional dedicated secret for mobile bearer tokens.
# If omitted, the mobile sync API falls back to SESSION_SECRET.
MOBILE_SESSION_SECRET=your-mobile-token-secret-here

# Local development only: bypass auth middleware on localhost
# Set to true only on your machine while testing
DEV_BYPASS_AUTH=false

# Local development only: use in-memory mock appointments instead of Supabase
# Useful when Supabase env values are missing or network is unavailable
DEV_USE_MOCK_APPOINTMENTS=false
